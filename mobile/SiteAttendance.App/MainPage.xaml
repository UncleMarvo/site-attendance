<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SiteAttendance.App.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            
            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="Cute dot net bot waving hi to you!" />

            <Label
                Text="Site Attendance MVP"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Hands-free geofence attendance tracking"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Hands-free geofence attendance tracking" />

            <Button
                x:Name="InitializeBtn"
                Text="Initialize Geofences"
                Clicked="OnInitializeClicked"
                HorizontalOptions="Fill" />

            <Button
                x:Name="SimulateEnterBtn"
                Text="Simulate Enter Event"
                Clicked="OnSimulateEnterClicked"
                HorizontalOptions="Fill" />

            <Label
                x:Name="StatusLabel"
                Text="Tap Initialize to register geofences"
                HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
